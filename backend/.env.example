# ── OpenSearch (verified: wazuh-cluster, v7.10.2) ─────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGE_ME
OPENSEARCH_VERIFY_SSL=false

# Local dev Windows (khong can VPS): copy file nay thanh .env va dat SOC_MOCK_DATA=true
SOC_MOCK_DATA=false

# ── Index pattern (verified: wazuh-alerts-4.x-2026.03.23) ─────────
INDEX_WAZUH_ALERTS=wazuh-alerts-4.x-*
INDEX_AI_ANOMALY=ai-anomaly-alerts

# ── AI Engine ─────────────────────────────────────────────────────
# AI Engine chạy trên VPS1 (cùng host với OpenSearch/Wazuh Manager)
AI_RISK_THRESHOLD=0.70
AI_BLOCK_AUTO=false

# ── Remote Block — SSH sang VPS Suricata ──────────────────────────
# VPS Suricata là nơi traffic thực sự đi vào (103.98.152.197)
# Để trống = chỉ block local, không SSH sang VPS Suricata
SURICATA_VPS_HOST=103.98.152.197
SURICATA_VPS_USER=root
SURICATA_VPS_KEY=/root/.ssh/id_rsa
SURICATA_VPS_PORT=22
# Chain iptables trên VPS Suricata: AI_BLOCK (khuyến nghị) hoặc INPUT
SURICATA_IPTABLES_CHAIN=AI_BLOCK
# Demo safety: chỉ block trên target mong muốn.
BLOCK_TARGET_LOCAL=false
BLOCK_TARGET_SURICATA=false
BLOCK_TARGET_AGENT=true

# ── SSH Safety / Whitelist — QUAN TRỌNG ─────────────────────────
# Port SSH của VPS đang chạy service này.
# Mô hình hiện tại: VPS Wazuh/AI = 22, VPS Agent = 2222.
SSH_PROTECTED_PORT=22
# Khi đổi Wi-Fi / đổi mạng, chỉ cần sửa IP public ở dòng dưới rồi restart service.
ADMIN_WHITELIST_IPS=YOUR_PUBLIC_IP,ANOTHER_ADMIN_PUBLIC_IP
LOCAL_IPTABLES_CHAIN=AI_BLOCK

# ── Remote Block — SSH sang VPS Agent ───────────────────────────
AGENT_VPS_HOST=
AGENT_VPS_USER=root
AGENT_VPS_KEY=/root/.ssh/id_rsa
# VPS Agent của anh đang mở SSH ở 2222.
AGENT_VPS_PORT=2222
AGENT_IPTABLES_CHAIN=AI_BLOCK

# ── Threat Intel ──────────────────────────────────────────────────
ABUSEIPDB_API_KEY=3938d64b323101a64d8b4777725fdcc85d77dbaad22f4bdbf2877d419678800851b0a8d268ecea0c

# ── WebSocket interval ────────────────────────────────────────────
WS_BROADCAST_INTERVAL=10
